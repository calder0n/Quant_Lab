# Copy to .env and adjust. Every backend variable uses the QL_ prefix.

QL_ENVIRONMENT=dev
QL_DEBUG=false

# Auth (set your own secret; used for JWT signing and broker-token encryption)
QL_SECRET_KEY=change-me-quantlab-local-secret
QL_AUTH_ENABLED=true

# PostgreSQL
QL_POSTGRES_USER=quantlab
QL_POSTGRES_PASSWORD=quantlab
QL_POSTGRES_DB=quantlab

# Market data
# Earliest candle to download (idempotent: already-stored ranges are never re-fetched)
QL_HISTORY_START=2020-01-01

# OANDA (a free "practice" account token works; never commit real credentials)
# Prefer configuring these in the portal (Broker settings): portal credentials
# are stored in PostgreSQL and take precedence over these variables.
QL_OANDA_API_TOKEN=
QL_OANDA_ACCOUNT_ID=
QL_OANDA_ENVIRONMENT=practice
